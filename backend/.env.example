# ══════════════════════════════════════════════════════════════════════
# GMS Veille Média — Variables d'environnement
# Copie ce fichier en .env et remplis toutes les valeurs
# JAMAIS commiter le vrai .env sur Git !
# ══════════════════════════════════════════════════════════════════════

# ── Base de données ─────────────────────────────────────────────────
# Format Neon : postgresql+asyncpg://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neodev?sslmode=require
# Format local : postgresql+asyncpg://ton_user@localhost:5432/veille_media
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ── Sécurité JWT ────────────────────────────────────────────────────
# Génère avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── URL Frontend (CORS) ─────────────────────────────────────────────
# En prod : https://gms-veille.vercel.app ou ton domaine custom
# En local : http://localhost:3000
FRONTEND_URL=https://TON_DOMAINE.vercel.app
APP_URL=https://TON_DOMAINE.com

# ── Claude / Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXX

# ── SerpAPI ─────────────────────────────────────────────────────────
SERPAPI_KEY=XXXX

# ── OpenRouter (optionnel — fallback LLM) ────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-XXXX

# ── OpenAI (optionnel) ───────────────────────────────────────────────
OPENAI_API_KEY=sk-XXXX

# ── Resend (emails newsletter) ───────────────────────────────────────
RESEND_API_KEY=re_XXXX
EMAIL_FROM=GMS Veille <noreply@elhamdani.ma>

# ── NewsData.io (optionnel — collecte Maroc AR+FR) ────────────────────
# Gratuit : 200 req/jour — https://newsdata.io
NEWSDATA_API_KEY=

# ── Redis (optionnel — file de tâches) ───────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── FlareSolverr (optionnel — bypass Cloudflare JS challenge) ─────────
FLARESOLVERR_URL=

# ── Date de démarrage du système ─────────────────────────────────────
SYSTEM_START_DATE=2025-03-01
